{
  "name": "@textyly/crossly-private-persistence-contracts",
  "version": "0.0.2",
  "description": "Shared contracts (pattern data model + HATEOAS links) for the Crossly Private Persistence service, consumable by clients such as crossly.ui.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "tsc --version && tsc",
    "build": "npm i && npm run compile",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/textyly/crossly.private.persistence.service.git",
    "directory": "contracts"
  },
  "homepage": "https://github.com/textyly/crossly.private.persistence.service/tree/main/contracts#readme",
  "bugs": {
    "url": "https://github.com/textyly/crossly.private.persistence.service/issues"
  },
  "keywords": [
    "crossly",
    "textyly",
    "contracts",
    "cross-stitch",
    "embroidery",
    "pattern"
  ],
  "author": "textyly community",
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}