{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@textyly/crossly-private-persistence-contracts": ["contracts/dist/index.d.ts"]
    },
    "strict": true,
    "sourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-tests"
  ]
}
